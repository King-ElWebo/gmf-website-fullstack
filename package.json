    "@radix-ui/react-accordion": "^1.2.12",
    "dotenv": "^17.4.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.2"
  },
  "devDependencies": {
