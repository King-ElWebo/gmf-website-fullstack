generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String?
  imageUrl      String?
  imageKey      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  catalogTypeId String
  sortOrder     Int         @default(0)
  catalogType   CatalogType @relation(fields: [catalogTypeId], references: [id])
  items         Item[]

  @@index([catalogTypeId])
  @@index([sortOrder])
}

model CatalogType {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  navLabel    String?
  showInNav   Boolean    @default(true)
  isDefault   Boolean    @default(false)
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categories  Category[]

  @@index([isActive, sortOrder])
}

model Item {
  id                      String                @id @default(cuid())
  title                   String
  slug                    String                @unique
  description             String?
  priceCents              Int?
  published               Boolean               @default(false)
  categoryId              String
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  sortOrder               Int                   @default(0)
  priceType               ItemPriceType         @default(FIXED)
  basePriceCents          Int?
  priceLabel              String?
  shortDescription        String?
  longDescription         String?
  videoUrl                String?
  depositRequired         Boolean               @default(false)
  depositLabel            String?
  depositInfo             String?
  cleaningFeeApplies      Boolean               @default(false)
  cleaningFeeLabel        String?
  cleaningFeeInfo         String?
  dryingFeeApplies        Boolean               @default(false)
  dryingFeeLabel          String?
  dryingFeeInfo           String?
  additionalCostsInfo     String?
  deliveryAvailable       Boolean               @default(false)
  pickupAvailable         Boolean               @default(false)
  requiresDeliveryAddress Boolean               @default(false)
  deliveryInfo            String?
  usageInfo               String?
  rentalNotes             String?
  setupRequirements       String?
  accessRequirements      String?
  trackInventory          Boolean               @default(true)
  totalStock              Int                   @default(1)
  bookingItems            BookingItem[]
  calendarBlockerItems    CalendarBlockerItem[]
  category                Category              @relation(fields: [categoryId], references: [id])
  images                  ItemImage[]

  @@index([categoryId])
  @@index([sortOrder])
}

model ItemImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  itemId    String
  createdAt DateTime @default(now())
  key       String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model SiteSettings {
  id             String           @id @default(cuid())
  key            String           @unique @default("default")
  phone          String?
  email          String?
  address        String?
  openingHours   String?
  noticeText     String?
  heroTitle      String?
  heroText       String?
  additionalInfo String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  socialLinks    SiteSocialLink[]
}

model SiteSocialLink {
  id         String       @id @default(cuid())
  settingsId String
  platform   String
  label      String?
  url        String
  sortOrder  Int          @default(0)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  settings   SiteSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([settingsId])
  @@index([sortOrder])
}

model CalendarBlocker {
  id                String                @id @default(cuid())
  title             String
  status            String                @default("blocked")
  startDate         DateTime
  endDate           DateTime
  appliesToAllItems Boolean               @default(false)
  description       String?
  contactName       String?
  source            String                @default("manual")
  createdBy         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  items             CalendarBlockerItem[]

  @@index([startDate, endDate])
  @@index([status])
}

model GlobalImage {
  id        String   @id @default(cuid())
  url       String
  key       String
  alt       String?
  area      String   @default("OTHER")
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([area, published])
}

model CalendarBlockerItem {
  id        String          @id @default(cuid())
  blockerId String
  itemId    String
  blocker   CalendarBlocker @relation(fields: [blockerId], references: [id], onDelete: Cascade)
  item      Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([blockerId, itemId])
  @@index([itemId])
}

enum ItemPriceType {
  FIXED
  ON_REQUEST
  FROM_PRICE
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model Booking {
  id                           String              @id @default(cuid())
  referenceCode                String              @unique
  status                       String              @default("requested")
  startDate                    DateTime
  endDate                      DateTime
  deliveryType                 String
  customerMessage              String?
  billingAddressSameAsDelivery Boolean             @default(true)
  billingAddress               Json?
  totalPriceCents              Int?
  hasIndividualPricing         Boolean             @default(false)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  customer                     BookingCustomer?
  items                        BookingItem[]
  notes                        InternalNote[]
  calendarSync                 CalendarSyncRecord?

  @@index([status])
  @@index([startDate, endDate])
}

model BookingCustomer {
  id           String  @id @default(cuid())
  bookingId    String  @unique
  firstName    String
  lastName     String
  email        String
  phone        String?
  addressLine1 String?
  zip          String?
  city         String?
  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([email])
}

model BookingItem {
  id                        String  @id @default(cuid())
  bookingId                 String
  itemId                    String
  quantity                  Int     @default(1)
  resourceTitle             String?
  priceType                 String?
  basePriceCents            Int?
  priceLabel                String?
  displayPrice              String?
  pricingMode               String?
  pricingReason             String?
  bookingDays               Int?
  calculatedUnitPriceCents  Int?
  calculatedTotalPriceCents Int?
  booking                   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item                      Item    @relation(fields: [itemId], references: [id])

  @@index([bookingId])
  @@index([itemId])
}

model InternalNote {
  id        String   @id @default(cuid())
  bookingId String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model CalendarSyncRecord {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  externalEventId String?
  syncStatus      String    @default("pending")
  lastSyncedAt    DateTime?
  syncError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([syncStatus])
}
